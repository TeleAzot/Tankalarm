@page "/"
@inject NavigationManager NavigationManager
@inject PriceAlarmService PriceAlarmSvc

<header class="d-flex">
    <h2>Aktive Alarme</h2>
    <button class="icon-lg bi bi-plus" @onclick="AddAlarm"></button>
</header>

<div class="alarmcard-container">
    <div class="alarmcard">
        <span>Diesel</span>
        <span>1,60 €</span>
        <button class="icon-md bi bi-pencil"></button>
        <button class="icon-md bi bi-trash"></button>
    </div>

    <div class="alarmcard">
        <span class="">Super E5</span>
        <span class="">1,70 €</span>
        <button class="icon-md bi bi-pencil"></button>
        <button class="icon-md bi bi-trash"></button>
    </div>
</div>

<footer>
    <button @onclick="NearbySearch">Umkreissuche</button>
</footer>

@code
{
    protected override async Task OnInitializedAsync()
    {
        await Permissions.RequestAsync<Permissions.LocationAlways>();
        //get last known location on start up for requesting all necessary permissions
        var location = await Geolocation.Default.GetLastKnownLocationAsync();
        await base.OnInitializedAsync();
    }

