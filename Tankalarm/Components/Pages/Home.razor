@page "/"
@using Tankalarm.Data.API.Services
@inject NavigationManager NavigationManager

<header class="d-flex">
    <h2>Aktive Alarme</h2>
    <button class="icon-lg bi bi-plus" @onclick="AddAlarm"></button>
</header>

<div class="alarmcard-container">
    <div class="alarmcard">
        <span>Diesel</span>
        <span>1,60 €</span>
        <button class="icon-md bi bi-pencil"></button>
        <button class="icon-md bi bi-trash"></button>
    </div>

    <div class="alarmcard">
        <span class="">Super E5</span>
        <span class="">1,70 €</span>
        <button class="icon-md bi bi-pencil"></button>
        <button class="icon-md bi bi-trash"></button>
    </div>
</div>

<footer>
    <button @onclick="NearbySearch">Umkreissuche</button>
</footer>

@code
{
    protected override async Task OnInitializedAsync()
    {
        var apiClient = new TankerkoenigService();
        var stat = await apiClient.GetCheapestFuelPricesAsync(10.024963, 48.797592, 5, "E5");
        await base.OnInitializedAsync();
    }

    private void AddAlarm()
    {
        NavigationManager.NavigateTo("AddAlarm");
    }

    private void NearbySearch()
    {
        NavigationManager.NavigateTo("NearbySearch");
    }
}